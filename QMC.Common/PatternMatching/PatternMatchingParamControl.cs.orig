        public PatternMatchingParamControl(MultiPatternMatchingVisionPart visionpart, bool IsMaint)
        {
            m_Owner = visionpart;
            if (visionpart != null)
            {
                m_MultiPatternMatchingParameters = visionpart.GetPatternMatchingParameters();
            }
            else
            {
                m_MultiPatternMatchingParameters = new MultiPatternMatchingParameters();
            }
            if (m_Owner != null)
                m_Camera = m_Owner.Camera;
            //m_Camera = camera;
            InitializeComponent();
            this.SetStyle(ControlStyles.OptimizedDoubleBuffer | ControlStyles.UserPaint | ControlStyles.AllPaintingInWmPaint, true);
            this.UpdateStyles();

            this.pictureBoxTrainImage.BackColor = FormBaseConfiguration.Instance.BackColor;
            this.pictureBoxTrainImage.ImageChanged += TrainImageChanged;
            this.baseListBoxTrainList.BackColor = FormBaseConfiguration.Instance.ContentBackColor;
            Font defaultFont = this.baseListBoxTrainList.Font;
            this.baseListBoxTrainList.Font = new Font(defaultFont.FontFamily, FormBaseConfiguration.Instance.ControlFontSize);

            SetPatternMatchingParam(m_MultiPatternMatchingParameters);
            InitROIControl();
            InitSearchControl(IsMaint);
        }

        private void InitParamGroupControl(ParamGroup group)
        {
            m_ParamGroupControl = new ParamGroupControl(group, FormBaseConfiguration.Instance.InnerSubParamGroupControlWidth);
            m_ParamGroupControl.Location = new Point(FormBaseConfiguration.Instance.MaintControlFisrtLocation.X, pictureBoxTrainImage.Location.Y + pictureBoxTrainImage.Size.Height + FormBaseConfiguration.Instance.ControlGap);
            m_ParamGroupControl.EnableExpand(false);
            baseGroupBoxPatternMatching.Controls.Add(m_ParamGroupControl);
        }
        private void InitSearchControl(bool IsMaint)
        {
            if (IsMaint)
            {
                this.m_ResultControl = new PatternMatchingResultControl();
                this.m_ResultControl.Location = new Point(this.m_RoiControl.Location.X, this.m_RoiControl.Location.Y + this.m_RoiControl.Height + FormBaseConfiguration.Instance.ControlGap_5);
                this.m_ResultControl.SearchButtonClick += ResultControl_SearchButtonClick;
                baseGroupBoxPatternMatching.Controls.Add(this.m_ResultControl);
            }
            else
            {
                this.m_ResultControl = new PatternMatchingResultControl();
                this.baseGroupBoxPatternMatching.MaximumSize = new Size(this.baseGroupBoxPatternMatching.Width, this.baseGroupBoxPatternMatching.Height - this.m_ResultControl.Height - FormBaseConfiguration.Instance.ControlGap_5);
                this.Size = this.baseGroupBoxPatternMatching.Size;
            }
        }

