        private void ResultControl_SearchButtonClick()
        {
            ParamGroup group = this.m_ParamGroupControl.GetParamGroup();
            m_MultiPatternMatchingParameters.SetParamGroup(group);
            PatternMatchingResult result = null;
            if (m_Owner != null)
            {
                if(m_ImageViewer != null)
                {
                    m_ImageViewer.ResultOverlays.Clear();
                }

                m_Owner.OnSearch(m_Owner.GetInspectStartPoint(), m_Owner.GetInspectEndPoint(), m_MultiPatternMatchingParameters, m_Owner.GetIlluminationDataSet());
                result = m_Owner.GetResult();
                if (result != null)
                {
                    if (result.Values.Count > 0)
                    {
                        this.m_ResultControl.SetResultData(result.Values[0].X, result.Values[0].Y, result.Values[0].R);
                    }

                    if(m_ImageViewer != null)
                    {
                        foreach (var overlay in result.ResultOverlays)
                        {
                            //m_visionImageViewer.NormalOverlays.Add(overlay);
                            m_ImageViewer.ResultOverlays.Add(overlay);
                            overlay.Visible = true;
                        }

                        m_ImageViewer.Display();
                    }
                }
            }
        }

        private void ParamTextControlTolerance_ParamValueChanged()
