        public void Init(string strName)
        {
            if(IlluminationDataSet == null)
            {
                IlluminationDataSet = new IlluminationDataSet(strName);
            }
            if(PatternMatchingParameter == null)
            {
                PatternMatchingParameter = new PatternMatchingParameters();
            }

            if (MultiPatternMatchingParameter == null)
            {
                MultiPatternMatchingParameter = new MultiPatternMatchingParameters();
                MultiPatternMatchingParameter.SetParameter(PatternMatchingParameter);
            }
            if (FinderParamter == null)
                FinderParamter = new DieFindParameter();

            m_strGroupNameRefind = "Refind";
            m_strGroupMultiPatternMatchingParameter = "MultiPatternMatchingParameter";
        }

        public int GetInspectionRoi(Point pointCenter, ref Point pointStart, ref Point pointEnd)
        {
            int ret = 0;
            int width =Math.Abs(InspectRoiEndLocation.X - InspectRoiStartLocation.X);
            int height = Math.Abs(InspectRoiEndLocation.Y - InspectRoiStartLocation.Y);

            pointStart.X = pointCenter.X - (width / 2);
            pointStart.Y = pointCenter.Y - (height / 2);

            pointEnd.X = pointStart.X + width;
            pointEnd.Y = pointStart.Y + height;


            return ret;
        }

        public override ListParam ToListParam()
        {
            ListParam listParam = new ListParam(); 
            ParamGroup paramGroup = new ParamGroup();
            paramGroup.Name = this.GetType().Name;
            {
                Param param = new Param();
                param.SetParam(nameof(ImageSave), Param.DisplayTypeKey.CheckBox, ImageSave, Param.ValueTypeKey.Bool, paramGroup.Name);
                paramGroup.AddParam(param);
            }
            {
                ParamGroup groupRefind = new ParamGroup();
                groupRefind.Name = m_strGroupNameRefind;
                {
                    Param param = new Param();
                    param.SetParam(nameof(UseDieRefind), Param.DisplayTypeKey.CheckBox, UseDieRefind, Param.ValueTypeKey.Bool, groupRefind.Name);
                    groupRefind.AddParam(param);
                }

                {
                    Param param = new Param();
                    param.SetParam(nameof(IsInvertedThreshold), Param.DisplayTypeKey.CheckBox, IsInvertedThreshold, Param.ValueTypeKey.Bool, groupRefind.Name);
                    groupRefind.AddParam(param);
                }

                {
                    Param param = new Param();
                    param.SetParam(nameof(ChipThreshold), Param.DisplayTypeKey.Text, ChipThreshold, Param.ValueTypeKey.Int, groupRefind.Name);
                    groupRefind.AddParam(param);
                }
                paramGroup.SetGroup(groupRefind);
            }
            
            listParam.SetGroup(paramGroup);
            return listParam;
        }

        public override void SetParam(ListParam listParam)
        {
            ParamGroup group = listParam.GetGroup(this.GetType().Name);

            if (group != null)
            {
                Param param = null;

                param = group.GetParam((int)ParamDieFinderRecipeKey.ImageSave);
                if (param != null)
                {
                    bool value = false;
                    if (param.GetBoolValue(ref value))
                    {
                        ImageSave = value;
                    }
                }

                {
                    ParamGroup groupRefinde = listParam.GetGroup(m_strGroupNameRefind);
                    param = groupRefinde.GetParam((int)ParamDieFinderRecipeKey.UseDieRefind);
                    if (param != null)
                    {
                        bool value = false;
                        if (param.GetBoolValue(ref value))
                        {
                            UseDieRefind = value;
                        }
                    }

                    param = groupRefinde.GetParam((int)ParamDieFinderRecipeKey.IsInvertedThreshold);
                    if (param != null)
                    {
                        bool value = false;
                        if (param.GetBoolValue(ref value))
                        {
                            IsInvertedThreshold = value;
                        }
                    }

                    param = groupRefinde.GetParam((int)ParamDieFinderRecipeKey.ChipThreshold);
                    if (param != null)
                    {
                        int value = 0;
                        if (param.GetIntValue(ref value))
                        {
                            ChipThreshold = value;
                        }
                    }
                }

                //{
                //    ParamGroup subGroup = group.GetGroup(m_strGroupMultiPatternMatchingParameter);
                //    this.MultiPatternMatchingParameter.SetParamGroup(subGroup);
                //}
            }
        }
        public override IlluminationDataList GetIlluminationDatas()
        {
            IlluminationDataList IlluminationrList = new IlluminationDataList();
            IlluminationrList.Add(IlluminationDataSet);
            return IlluminationrList;
        }

        public string GetRefindeGroupName()
        {
            return m_strGroupNameRefind;
        }

        public ParamGroup GetRefindGroup()
        {
            ListParam list = ToListParam();
            ParamGroup group = list.GetGroup();
            ParamGroup subGroup = group.GetGroup(m_strGroupNameRefind);
            
            return subGroup;
        }
    }

