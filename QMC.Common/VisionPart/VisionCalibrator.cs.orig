        public int MovePosition(string strPosition)
        {
            int ret = 0;

            XytCoordinate position = VisonCalibratorConfig.GetCalibratorPosition(strPosition);

            if ((ret = Stage.MovePosition(position)) != 0)
            {
                return ret;
            }

            return ret;
        }

        public void SetPositionData(string strPosition)
        {
            XytCoordinate currentPosition = new XytCoordinate();
            this.Stage.GetActualPosition(ref currentPosition);
            VisonCalibratorConfig.SetCalibratorPosition(strPosition, TargetType.Base, currentPosition);
            Equipment.SaveConfig();
        }

        [Serializable]
        public class DirectionResult
        {
            #region Field
            private PointD m_PixelLocation;
            private MoveDirection m_Direction;
            #endregion

            #region Constructor
            public DirectionResult(PointD pixelLocation, MoveDirection direction)
            {
                this.PixelLocation = pixelLocation;
                this.Direction = direction;
            }

            public DirectionResult() : this(PointD.Empty, MoveDirection.Start) { }
            #endregion

            #region Property
            public MoveDirection Direction
            {
                get { return this.m_Direction; }
                set { this.m_Direction = value; }
            }

            public PointD PixelLocation
            {
                get { return this.m_PixelLocation; }
                set { this.m_PixelLocation = value; }
            }
            #endregion
        }
        [Serializable]
        public class DirectionResultKeyedCollection : KeyedCollection<MoveDirection, DirectionResult>
        {
            protected override MoveDirection GetKeyForItem(DirectionResult item)
            {
                return item.Direction;
            }
        }
    }
