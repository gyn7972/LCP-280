                // [FIX] UpFeeder() ≥ª∫Œ WaitLiftStateOrAlarm()∞° 2030/2031¿ª πþª˝Ω√≈¥.
                //       ø©±‚º≠¥¬ BinLoadingFailed(2000)∑Œ µ§¡ˆ æ ¿Ω.
                return -1;
            }
            Log.Write(this, "MoveToReay End");


            return nRet;
        }

