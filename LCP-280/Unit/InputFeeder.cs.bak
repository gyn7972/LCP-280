        private volatile bool _exchangeStandbyForNextLoad = false; // ľđ·Îµĺ ČÄ ´ŮŔ˝ ·ÎµůŔ» ąŮÄÚµĺżˇĽ­ ˝ĂŔŰ
        public bool ExchangeStandbyForNextLoad
        {
