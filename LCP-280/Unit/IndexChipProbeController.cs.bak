        ///  6) ChipProber °Ë»ç żä±¸ ˝ĹČŁ Ŕü´Ţ
        ///  7) °Ë»çżĎ·á ˝ĹČŁ ´ë±â
        ///  8) °Ë»çżĎ·á Ăł¸®
        ///  9) ProbeCard Ready ZĂŕ ÇĎ°­
        ///  10) żĎ·á
        /// </summary>
