namespace MicroLedDieTransfers2
{
    public enum SeletedROI
    {
        Train,
        Inspect,
        None,
    }
    public delegate void ROIButtonClickEventHandler();
    public partial class MaintROIControl : UserControl
    {
        public event ROIButtonClickEventHandler ROIButtonClick;
        private MultiPatternMatchingVisionPart m_Owner;
        private SeletedROI m_selectROIMode;
        private Point m_TrainCenterposition;
        private Size m_TrainSize;
        private Point m_InspectCenterposition;
        private Size m_InspectSize;
        private int m_MoveToke;
        private int m_SizeToke;
        private Size m_FullSize;
        protected VisionImageViewer m_ImageViewer;
        protected RoiVisionTool m_SelectRoi;
        public MaintROIControl(MultiPatternMatchingVisionPart visionPart)
        {
            InitializeComponent();
            m_Owner = visionPart;
            m_selectROIMode = SeletedROI.Train;
            if (m_Owner != null)
            {
                m_FullSize = m_Owner.Camera.Resolution;
            }
            m_MoveToke = 10;
            m_SizeToke = 10;
            m_TrainCenterposition = new Point();
            m_TrainSize = new Size();
            m_InspectCenterposition = new Point();
            m_InspectSize = new Size();

            CalculateRoiParameter();
            CalculateCenterPosition();
            CalculateROISize();
            this.baseToggleButtonTrain.UpdateToggleStatus(true);
            InitTrainParamGroupControl();

            baseButtonUp.BackColor = Color.Transparent;
            baseButtonDown.BackColor = Color.Transparent;
            baseButtonLeft.BackColor = Color.Transparent;
            baseButtonRight.BackColor = Color.Transparent;
            baseButtonCenter.BackColor = Color.Transparent;
            baseButtonXSizeUp.BackColor = Color.Transparent;
            baseButtonXSizeDown.BackColor = Color.Transparent;
            baseButtonYSizeUp.BackColor = Color.Transparent;
            baseButtonYSizeDown.BackColor = Color.Transparent;
        }
        public MaintROIControl() : this(null)
        {

        }

        private void CalculateRoiParameter()
        {
            //CalculateCenterPosition();
            //CalculateROISize();
        }
        private void CalculateCenterPosition()
        {
            Point startPosition = new Point();
            Point endPosition = new Point();

            if (m_Owner != null)
            {
                startPosition = m_Owner.GetTrainStartPoint();
                endPosition = m_Owner.GetTrainEndPoint();
                m_TrainCenterposition = new Point(((endPosition.X - startPosition.X) / 2) + startPosition.X, ((endPosition.Y - startPosition.Y) / 2) + startPosition.Y);

                startPosition = m_Owner.GetInspectStartPoint();
                endPosition = m_Owner.GetInspectEndPoint();
                m_InspectCenterposition = new Point(((endPosition.X - startPosition.X) / 2) + startPosition.X, ((endPosition.Y - startPosition.Y) / 2) + startPosition.Y);
            }
        }

        private void CalculateROISize()
        {
            Point startPosition = new Point();
            Point endPosition = new Point();
            if (m_Owner != null)
            {
                startPosition = m_Owner.GetTrainStartPoint();
                endPosition = m_Owner.GetTrainEndPoint();
                m_TrainSize = new Size((endPosition.X - startPosition.X), (endPosition.Y - startPosition.Y));

                startPosition = m_Owner.GetInspectStartPoint();
                endPosition = m_Owner.GetInspectEndPoint();
                m_InspectSize = new Size((endPosition.X - startPosition.X), (endPosition.Y - startPosition.Y));
            }
        }

        private void CalculateTrainROIPosition(out Point startPosition, out Point endPosition)
        {
            startPosition = new Point();
            endPosition = new Point();

            startPosition = new Point((int)(m_TrainCenterposition.X - m_TrainSize.Width / 2), (int)(m_TrainCenterposition.Y - m_TrainSize.Height / 2));
            endPosition = new Point((int)(m_TrainCenterposition.X + m_TrainSize.Width / 2), (int)(m_TrainCenterposition.Y + m_TrainSize.Height / 2));
        }

        private void CalculateInspectROIPosition(out Point startPosition, out Point endPosition)
        {
            startPosition = new Point();
            endPosition = new Point();

            startPosition = new Point((int)(m_InspectCenterposition.X - m_InspectSize.Width / 2), (int)(m_InspectCenterposition.Y - m_InspectSize.Height / 2));
            endPosition = new Point((int)(m_InspectCenterposition.X + m_InspectSize.Width / 2), (int)(m_InspectCenterposition.Y + m_InspectSize.Height / 2));
        }

        private void UpdateROIInformation()
        {
            Point startPosition = new Point();
            Point endPosition = new Point();

            CalculateTrainROIPosition(out startPosition, out endPosition);
            m_Owner.SetTrainStartPoint(startPosition);
            m_Owner.SetTrainEndPoint(endPosition);

            CalculateInspectROIPosition(out startPosition, out endPosition);
            m_Owner.SetInspectStartPoint(startPosition);
            m_Owner.SetInspectEndPoint(endPosition);
        }

        private void InitTrainParamGroupControl()
        {
            {
                Param param = new Param();
                param.SetParam("Move Toke", Param.DisplayTypeKey.Text, m_MoveToke, Param.ValueTypeKey.Int, "ROI");
                this.paramTextControlMoveToke.InitControl(param);
            }
            {
                Param param = new Param();
                param.SetParam("Size Toke", Param.DisplayTypeKey.Text, m_SizeToke, Param.ValueTypeKey.Int, "ROI");
                this.paramTextControlSizeToke.InitControl(param);
            }
            {
                Param param = new Param();
                param.SetParam("Center Point", Param.DisplayTypeKey.Text, m_TrainCenterposition, Param.ValueTypeKey.Point, "ROI");
                this.paramDualTextControlCenter.InitControl(param);
            }
            {
                Param param = new Param();
                param.SetParam("ROI Size", Param.DisplayTypeKey.Text, m_TrainSize, Param.ValueTypeKey.Size, "ROI");
                this.paramDualTextControlSize.InitControl(param);
            }
        }
        private void InitInspectParamGroupControl()
        {
            {
                Param param = new Param();
                param.SetParam("Move Toke", Param.DisplayTypeKey.Text, m_MoveToke, Param.ValueTypeKey.Int, "ROI");
                this.paramTextControlMoveToke.InitControl(param);
            }
            {
                Param param = new Param();
                param.SetParam("Size Toke", Param.DisplayTypeKey.Text, m_SizeToke, Param.ValueTypeKey.Int, "ROI");
                this.paramTextControlSizeToke.InitControl(param);
            }
            {
                Param param = new Param();
                param.SetParam("Center Point", Param.DisplayTypeKey.Text, m_InspectCenterposition, Param.ValueTypeKey.Point, "ROI");
                this.paramDualTextControlCenter.InitControl(param);
            }
            {
                Param param = new Param();
                param.SetParam("ROI Size", Param.DisplayTypeKey.Text, m_InspectSize, Param.ValueTypeKey.Size, "ROI");
                this.paramDualTextControlSize.InitControl(param);
            }
        }

        private void SetParamGroupControlData()
        {
            {
                Param param = this.paramTextControlMoveToke.GetParamData();
                if (param != null)
                {
                    int value = 0;
                    if (param.GetIntValue(ref value))
                    {
                        this.m_MoveToke = value;
                    }
                }
            }
            {
                Param param = this.paramTextControlSizeToke.GetParamData();
                if (param != null)
                {
                    int value = 0;
                    if (param.GetIntValue(ref value))
                    {
                        this.m_SizeToke = value;
                    }
                }
            }
            if (m_selectROIMode == SeletedROI.Train)
            {
                {
                    Param param = this.paramDualTextControlCenter.GetParamData();
                    if (param != null)
                    {
                        Point value = new Point();
                        if (param.GetPointValue(ref value))
                        {
                            this.m_TrainCenterposition = value;
                        }
                    }
                }
                {
                    Param param = this.paramDualTextControlSize.GetParamData();
                    if (param != null)
                    {
                        Size value = new Size();
                        if (param.GetSizeValue(ref value))
                        {
                            this.m_TrainSize = value;
                        }
                    }
                }
            }
            else if (m_selectROIMode == SeletedROI.Inspect)
            {
                {
                    Param param = this.paramDualTextControlCenter.GetParamData();
                    if (param != null)
                    {
                        Point value = new Point();
                        if (param.GetPointValue(ref value))
                        {
                            this.m_InspectCenterposition = value;
                        }
                    }
                }
                {
                    Param param = this.paramDualTextControlSize.GetParamData();
                    if (param != null)
                    {
                        Size value = new Size();
                        if (param.GetSizeValue(ref value))
                        {
                            this.m_InspectSize = value;
                        }
                    }
                }
            }
        }

        private void baseToggleButtonTrain_Click(object sender, EventArgs e)
        {
            RoiVisionTool roi = m_Owner.GetTrainRoi();
            
            bool IsClicked = this.baseToggleButtonTrain.GetButtonStatus();
            if (IsClicked)
            {
                this.m_selectROIMode = SeletedROI.None;
                this.baseToggleButtonTrain.UpdateToggleStatus(!IsClicked);
                
                if(roi != null)
                {
                    m_ImageViewer.NormalOverlays.Remove(roi.Parameter.Overlay);
                }
            }
            else
            {
                this.m_selectROIMode = SeletedROI.Train;
                this.baseToggleButtonTrain.UpdateToggleStatus(!IsClicked);
                this.baseToggleButtonInspect.UpdateToggleStatus(IsClicked);
                
                if (roi != null)
                {
                    if(m_SelectRoi != null)
                    {
                        m_ImageViewer.NormalOverlays.Remove(m_SelectRoi.Parameter.Overlay);
                    }
                    m_ImageViewer.NormalOverlays.Add(roi.Parameter.Overlay);
                    m_SelectRoi = roi;

                }
            }
            CalculateRoiParameter();
            InitTrainParamGroupControl();
        }

        private void baseToggleButtonInspect_Click(object sender, EventArgs e)
        {
            RoiVisionTool roi = m_Owner.GetInspectRoi();
            bool IsClicked = this.baseToggleButtonInspect.GetButtonStatus();
            if (IsClicked)
            {
                this.m_selectROIMode = SeletedROI.None;
                this.baseToggleButtonInspect.UpdateToggleStatus(!IsClicked);
                if (roi != null)
                {
                    m_ImageViewer.NormalOverlays.Remove(roi.Parameter.Overlay);
                }
            }
            else
            {
                this.m_selectROIMode = SeletedROI.Inspect;
                this.baseToggleButtonInspect.UpdateToggleStatus(!IsClicked);
                this.baseToggleButtonTrain.UpdateToggleStatus(IsClicked);
                if (roi != null)
                {
                    if (m_SelectRoi != null)
                    {
                        m_ImageViewer.NormalOverlays.Remove(m_SelectRoi.Parameter.Overlay);
                    }
                    m_ImageViewer.NormalOverlays.Add(roi.Parameter.Overlay);
                    m_SelectRoi = roi;
                }
            }
            CalculateRoiParameter();
            InitInspectParamGroupControl();
        }

        private void baseButtonLocation_Click(object sender, EventArgs e)
        {
            BaseButton button = sender as BaseButton;
            SetParamGroupControlData();
            if (this.m_selectROIMode == SeletedROI.Train)
            {
                if (button == this.baseButtonCenter)
                {
                    m_TrainCenterposition = new Point(m_FullSize.Width / 2, m_FullSize.Height / 2);
                }
                else if (button == this.baseButtonRight)
                {
                    m_TrainCenterposition.X += m_MoveToke;
                }
                else if (button == this.baseButtonLeft)
                {
                    m_TrainCenterposition.X -= m_MoveToke;
                }
                else if (button == this.baseButtonDown)
                {
                    m_TrainCenterposition.Y += m_MoveToke;
                }
                else if (button == this.baseButtonUp)
                {
                    m_TrainCenterposition.Y -= m_MoveToke;
                }
                m_SelectRoi.Parameter.CenterLocation = m_TrainCenterposition;
                InitTrainParamGroupControl();
            }
            else if (this.m_selectROIMode == SeletedROI.Inspect)
            {
                if (button == this.baseButtonCenter)
                {
                    m_InspectCenterposition = new Point(m_FullSize.Width / 2, m_FullSize.Height / 2);
                }
                else if (button == this.baseButtonRight)
                {
                    m_InspectCenterposition.X += m_MoveToke;
                }
                else if (button == this.baseButtonLeft)
                {
                    m_InspectCenterposition.X -= m_MoveToke;
                }
                else if (button == this.baseButtonDown)
                {
                    m_InspectCenterposition.Y += m_MoveToke;
                }
                else if (button == this.baseButtonUp)
                {
                    m_InspectCenterposition.Y -= m_MoveToke;
                }
                m_SelectRoi.Parameter.CenterLocation = m_InspectCenterposition;
                InitInspectParamGroupControl();
            }

            if (ROIButtonClick != null)
            {
                ROIButtonClick();
            }
        }

        private void baseButtonSize_Click(object sender, EventArgs e)
        {
            BaseButton button = sender as BaseButton;
            SetParamGroupControlData();
            if (this.m_selectROIMode == SeletedROI.Train)
            {
                if (button == this.baseButtonXSizeUp)
                {
                    this.m_TrainSize.Width += m_SizeToke;
                    this.m_TrainCenterposition.X += (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonXSizeDown)
                {
                    this.m_TrainSize.Width -= m_SizeToke;
                    this.m_TrainCenterposition.X -= (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonYSizeUp)
                {
                    this.m_TrainSize.Height += m_SizeToke;
                    this.m_TrainCenterposition.Y += (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonYSizeDown)
                {
                    this.m_TrainSize.Height -= m_SizeToke;
                    this.m_TrainCenterposition.Y -= (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonFullSize)
                {
                    this.m_TrainSize = m_FullSize;
                    this.m_TrainCenterposition = new Point((int)(m_FullSize.Width / 2), (int)(m_FullSize.Height / 2));
                }
                m_SelectRoi.Parameter.Size = m_TrainSize;
                InitTrainParamGroupControl();
            }
            else if (this.m_selectROIMode == SeletedROI.Inspect)
            {
                if (button == this.baseButtonXSizeUp)
                {
                    this.m_InspectSize.Width += m_SizeToke;
                    this.m_InspectCenterposition.X += (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonXSizeDown)
                {
                    this.m_InspectSize.Width -= m_SizeToke;
                    this.m_InspectCenterposition.X -= (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonYSizeUp)
                {
                    this.m_InspectSize.Height += m_SizeToke;
                    this.m_InspectCenterposition.Y += (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonYSizeDown)
                {
                    this.m_InspectSize.Height -= m_SizeToke;
                    this.m_InspectCenterposition.Y -= (int)(m_SizeToke / 2);
                }
                else if (button == this.baseButtonFullSize)
                {
                    this.m_InspectSize = m_FullSize;
                    this.m_InspectCenterposition = new Point((int)(m_FullSize.Width / 2), (int)(m_FullSize.Height / 2));
                }
                m_SelectRoi.Parameter.Size = m_InspectSize;
                InitInspectParamGroupControl();
            }
            if (ROIButtonClick != null)
            {
                ROIButtonClick();
            }
        }

        private void baseButtonSave_Click(object sender, EventArgs e)
        {
            if (m_Owner != null)
            {
                if (m_Owner.Owner != null)
                {
                    UpdateROIInformation();
                    m_Owner.Owner.UpdateRecipeData();
                    m_Owner.Owner.SaveRecipeData();
                }
            }
        }

