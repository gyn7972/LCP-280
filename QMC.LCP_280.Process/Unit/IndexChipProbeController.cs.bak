            return recipe.ContectTop;
            //return Config.ContectTopMode;
        }
        protected override void OnMakeSequence()
        {
            base.OnMakeSequence();
            this.SequencePlayers.Add(RunInspectionReady);
            this.SequencePlayers.Add(RunInspection);

