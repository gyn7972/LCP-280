        [Category("Appearance")]
        [Description("ХиНКЦЎЙкНКРЧ ЦљЦЎ ХЉБт")]
        [DefaultValue(9f)]
        public float TextBoxFontSize
        {
            get => _textBoxFont.Size;
            set
            {
                if (value > 0 && Math.Abs(_textBoxFont.Size - value) > 0.01f)
                {
                    _textBoxFont = new Font(_textBoxFont.FontFamily, value);
                    RefreshProperties();
                }
            }
        }

        [Category("Appearance")]
        [Description("ХиНКЦЎЙкНКРЧ ЦљЦЎ")]
        [DefaultValue(typeof(Font), "ИМРК АэЕё, 9pt")]
        public Font TextBoxFont
        {
            get => _textBoxFont;
            set
            {
                if (value != null && !_textBoxFont.Equals(value))
                {
                    _textBoxFont = value;
                    RefreshProperties();
                }
            }
        }

        [Category("Appearance")]
        [Description("ХиНКЦЎЙкНКРЧ ХиНКЦЎ СЄЗФ")]
        [DefaultValue(HorizontalAlignment.Left)]
